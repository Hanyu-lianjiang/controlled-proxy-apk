<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_controlled_home"
    android:fitsSystemWindows="true">

    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="78dp"
        android:layout_marginEnd="-82dp"
        android:alpha="0.42"
        android:background="@drawable/bg_controlled_connect_halo_active" />

    <View
        android:layout_width="190dp"
        android:layout_height="190dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="-88dp"
        android:layout_marginTop="18dp"
        android:alpha="0.26"
        android:background="@drawable/bg_controlled_connect_halo" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="56dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="@string/controlled_home_title"
            android:textColor="@color/controlled_ink"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:includeFontPadding="false"
            android:text="@string/controlled_login_subtitle"
            android:textColor="@color/controlled_text_muted"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_controlled_ios_card"
            android:elevation="8dp"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="22dp"
            android:paddingEnd="20dp"
            android:paddingBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/controlled_backend_url"
                android:textStyle="bold"
                android:visibility="gone" />

            <EditText
                android:id="@+id/et_backend_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="http://43.108.8.13"
                android:inputType="textUri"
                android:singleLine="true"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="@string/controlled_username"
                android:textColor="@color/controlled_text_muted"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_username"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="9dp"
                android:background="@drawable/bg_controlled_ios_input"
                android:hint="@string/controlled_username_hint"
                android:includeFontPadding="false"
                android:inputType="textPersonName"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:singleLine="true"
                android:textColor="@color/controlled_ink"
                android:textColorHint="@color/controlled_text_muted"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:includeFontPadding="false"
                android:text="@string/controlled_license_code"
                android:textColor="@color/controlled_text_muted"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_license_code"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="9dp"
                android:background="@drawable/bg_controlled_ios_input"
                android:hint="@string/controlled_license_code_hint"
                android:includeFontPadding="false"
                android:inputType="textPassword"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:singleLine="true"
                android:textColor="@color/controlled_ink"
                android:textColorHint="@color/controlled_text_muted"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/controlled_device_id"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_device_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textIsSelectable="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/controlled_login_credential_notice"
                android:textColor="@color/controlled_text_muted"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:elevation="4dp"
                android:minHeight="56dp"
                android:text="@string/controlled_enter"
                android:textColor="@color/colorWhite"
                android:textSize="17sp"
                android:textStyle="bold"
                app:backgroundTint="@color/controlled_connect"
                app:cornerRadius="20dp" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sync"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:text="@string/controlled_sync"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:text="@string/controlled_logout"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
