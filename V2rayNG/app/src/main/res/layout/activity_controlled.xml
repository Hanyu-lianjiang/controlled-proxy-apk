<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/controlled_backend_url"
            android:visibility="gone"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_backend_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="http://43.108.8.13"
            android:inputType="textUri"
            android:visibility="gone"
            android:singleLine="true" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/controlled_username"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_username"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/controlled_username_hint"
            android:inputType="textPersonName"
            android:singleLine="true" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/controlled_license_code"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_license_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/controlled_license_code_hint"
            android:inputType="textPassword"
            android:singleLine="true" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/controlled_device_id"
            android:visibility="gone"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_device_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:textIsSelectable="true" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:padding="12dp"
            android:background="@color/md_theme_surfaceVariant"
            android:text="@string/controlled_not_logged_in" />

        <Button
            android:id="@+id/btn_login"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/controlled_login_and_sync" />

        <Button
            android:id="@+id/btn_sync"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/controlled_sync" />

        <Button
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/controlled_logout" />
    </LinearLayout>
</ScrollView>
